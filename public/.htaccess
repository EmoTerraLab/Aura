Options -Indexes
Options -MultiViews

# Activar mod_rewrite
RewriteEngine On

# Si el archivo o directorio existe físicamente, servirlo directamente
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Todo lo demás va al index.php
RewriteRule ^(.*)$ index.php [QSA,L]

# ═══════════════════════════════════════════════════════════════════════════════
# PWA: MIME Types y Cache para Service Worker y Manifest
# ═══════════════════════════════════════════════════════════════════════════════
<IfModule mod_mime.c>
    AddType application/manifest+json .webmanifest
    AddType application/json .json
</IfModule>

# Service Worker: NUNCA cachear (el navegador debe comprobar actualizaciones siempre)
<Files "sw.js">
    <IfModule mod_headers.c>
        Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
        Header set Service-Worker-Allowed "/"
    </IfModule>
</Files>

# Manifest: Cachear brevemente (1h) para no penalizar Lighthouse
<Files "manifest.json">
    <IfModule mod_headers.c>
        Header set Cache-Control "public, max-age=3600"
    </IfModule>
</Files>

# Bloquear acceso a archivos sensibles
RedirectMatch 403 ^/database/backups/
RedirectMatch 403 ^/storage/
RedirectMatch 403 \.(sqlite|log|sql|env)$

# Headers de caché para assets estáticos
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
</IfModule>

# Compresión gzip y brotli para mejorar rendimiento móvil
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript text/javascript application/json text/xml
    # Asegurar que los proxies no sirvan contenido comprimido a clientes que no lo soportan
    Header append Vary Accept-Encoding
</IfModule>
<IfModule mod_brotli.c>
    AddOutputFilterByType BROTLI_COMPRESS text/html text/css application/javascript text/javascript application/json text/xml
    Header append Vary Accept-Encoding
</IfModule>
